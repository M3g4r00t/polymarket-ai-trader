# Polymarket AI Trader - Environment Variables

# ===========================================
# REQUIRED: Wallet Configuration
# ===========================================

# Your Polygon wallet private key (with USDC balance)
# WARNING: Never commit this to git!
PRIVATE_KEY=0x...

# Alternative: Email/Magic wallet
# POLYMARKET_EMAIL=your@email.com
# POLYMARKET_PASSWORD=your_password

# ===========================================
# AI Integration (Local Ollama - FREE!)
# ===========================================

# Ollama runs locally, no API key needed!
# Make sure Ollama is running: ollama serve
# Required models (auto-detected):
#   - glm-4.7-flash (primary, best reasoning)
#   - qwen3:14b (fallback)

# Optional: Override Ollama URL (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# ===========================================
# OPTIONAL: Cloud AI (if Ollama unavailable)
# ===========================================

# OpenAI API key for sentiment analysis
# OPENAI_API_KEY=sk-...

# Anthropic API key for analysis
# ANTHROPIC_API_KEY=sk-ant-...

# ===========================================
# OPTIONAL: Telegram Notifications
# ===========================================

# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# ===========================================
# OPTIONAL: Advanced Settings
# ===========================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable dry run mode by default
DRY_RUN=true

# API endpoints (defaults shown)
# CLOB_API_URL=https://clob.polymarket.com
# GAMMA_API_URL=https://gamma-api.polymarket.com
# DATA_API_URL=https://data-api.polymarket.com